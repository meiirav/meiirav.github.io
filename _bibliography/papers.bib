
@article{mandl2026narrative,
  title     = {A Systematic Survey on Computational Analysis of Narrative Change in Public Discourse},
  author    = {Mandl, Christoph and Segal, Meirav and Echizen, Isao and Granitzer, Michael and Spinde, Timo},
  year      = {2026},
  note      = {Preprint, with the Media Bias Group},
  html      = {https://media-bias-research.org/wp-content/uploads/2026/06/mandl2026.pdf},
  abbr      = {Preprint},
  abstract  = {Changes in how events, actors, and social issues are represented in public discourse, often generalized as narrative change, can affect how audiences interpret and contest public issues. Despite growing computational work on narrative change analysis, no systematic review has synthesized its core methodological choices: analytical tasks, operationalizations of change, change-detection and analysis methods, and data sources. We therefore systematically identify and review 114 papers from 1,017 candidates published between 2020 and 2025 along these four dimensions. We find that most studies operationalize narrative change through content features and descriptive temporal trend tracking, while stylistic, distributional, and causal approaches remain underexplored.
}
}

